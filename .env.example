# CausePilot 配置文件示例
# 复制此文件为 .env 并修改配置值

# 可观测 MCP 服务器配置（用于获取可观测数据，https://github.com/zhangrj/observe-mcp-server）
OBSERVE_MCP_SERVER_HTTP_URL=http://localhost:8080/mcp
OBSERVE_MCP_BEARER_TOKEN=

# LLM 配置（PydanticAI 支持）
# Provider: openai, anthropic, groq, gemini, ollama
# 常用模型: gpt-4o, claude-3-sonnet-20240229, qwen-plus, gemini-pro
CAUSEPILOT_LLM_PROVIDER=openai
CAUSEPILOT_LLM_MODEL=qwen3.6-plus
CAUSEPILOT_LLM_API_KEY=
CAUSEPILOT_LLM_API_SECRET=
# API 端点（可选）
# OpenAI: https://api.openai.com/v1
# 阿里云百炼: https://dashscope.aliyuncs.com/compatible-mode/v1
# Ollama: http://localhost:11434/v1
CAUSEPILOT_LLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1

# 运行时配置
CAUSEPILOT_REQUEST_TIMEOUT=10
CAUSEPILOT_MAX_TOOL_CALLS=20
CAUSEPILOT_LOG_LEVEL=INFO

# FastAPI 服务配置
CAUSEPILOT_BIND_HOST=0.0.0.0
CAUSEPILOT_BIND_PORT=8080
